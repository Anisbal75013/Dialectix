# ── Dialectix Frontend — environment template ─────────────────────────────────
# Copy to .env.development or .env.production and fill in real values.
# All VITE_ variables are inlined into the browser bundle at build time.
#
# ⚠️  NEVER put the Anthropic API key here — it would be visible to any user
#     who inspects the network tab or the built JS bundle.
#     The key belongs exclusively in the backend .env.* files.

# URL of the NestJS AI backend gateway
# Development: http://localhost:3001
# Production:  https://your-backend-domain.com
VITE_BACKEND_URL=http://localhost:3001
