# ── Dialectix Frontend — template de configuration ───────────────────────────
# Copier ce fichier en .env.development ou .env.production et remplir les valeurs.
# Toutes les variables VITE_* sont injectées dans le bundle navigateur au build.
#
# ⚠️  JAMAIS ICI : ANTHROPIC_API_KEY, SUPABASE_SERVICE_ROLE_KEY ou toute clé secrète.
#     La clé Anthropic appartient UNIQUEMENT aux fichiers .env du BACKEND.
#     La SERVICE_ROLE_KEY Supabase appartient UNIQUEMENT au BACKEND.
# ─────────────────────────────────────────────────────────────────────────────

# URL du backend Dialectix (gateway IA)
# Dev  : http://localhost:3001
# Prod : https://dialectix-backend.vercel.app
VITE_BACKEND_URL=http://localhost:3001

# URL du projet Supabase (Supabase → Settings → API → Project URL)
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co

# Clé anon publique Supabase (Supabase → Settings → API → anon public)
# ✅ Safe côté navigateur — mais active bien le Row-Level Security sur tes tables
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.VOTRE_ANON_KEY
