# ── Dialectix Frontend — DEVELOPMENT environment ─────────────────────────────
# Loaded automatically by Vite when running `vite` or `vite dev`.
# All variables must start with VITE_ to be accessible in the browser bundle.
#
# ⚠️  NO API KEYS HERE — the Anthropic key lives only in the backend .env files.

# URL of the NestJS AI backend gateway
VITE_BACKEND_URL=http://localhost:3001
